{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "rootDir": ".",
    "outDir": ".tmp-tests",
    "types": ["node"]
  },
  "include": [
    "tests/**/*.ts",
    "src/store/appStore.ts",
    "src/constants/index.ts",
    "src/utils/requiredFields.ts",
    "src/utils/svgSanitizer.ts",
    "src/utils/svgFonts.ts",
    "src/types/**/*.ts"
  ]
}
